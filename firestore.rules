rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Centers: anyone authenticated can read, write (for seeding)
    match /centers/{centerId} {
      allow read, write: if request.auth != null;
      
      // Reviews subcollection
      match /reviews/{reviewId} {
        allow read, write: if request.auth != null;
      }
    }
    
    // Users: can only access their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Bookings subcollection (specific to user path)
      match /bookings/{bookingId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Allow collection group queries for bookings (used by Admin Dashboard)
    match /{path=**}/bookings/{bookingId} {
      allow read, write: if request.auth != null;
    }
  }
}
